-- UI Library: Plexus

-- 1. Tải Thư viện Plexus (Đã sửa lỗi link)
local Plexus = loadstring(game:HttpGet("https://raw.githubusercontent.com"))()

-- 2. Tạo Cửa Sổ Chính
local Window = Plexus:CreateWindow("6_7 HUB | The Strongest Battlegrounds")

-- 3. Tạo các Tab (Giống y hệt ảnh của bạn)
local TSBTab = Window:CreateTab("TSB Menu")
local CharTab = Window:CreateTab("Nhân Vật")
local TechTab = Window:CreateTab("Tech")
local PlayerTab = Window:CreateTab("Người Chơi")
local SettingTab = Window:CreateTab("Cài đặt")

-- ================= TAB: TSB MENU =================
TSBTab:AddLabel("The Strongest Battleground")
TSBTab:AddLabel("🚀 Chức năng chính")

-- Nút chạy RedzHub của bạn
TSBTab:AddButton("🔥 Script RedzHub", function()
    Plexus:Notification("Đang tải", "Đang khởi chạy RedzHub...", 3)
    loadstring(game:HttpGet("https://raw.githubusercontent.com"))()
end)

TSBTab:AddButton("Script CarbonHub", function()
    Plexus:Notification("Thông báo", "Chức năng này đang được cập nhật!", 3)
end)

-- ================= TAB: CÀI ĐẶT =================
SettingTab:AddLabel("Tùy chỉnh hệ thống")

-- Chức năng Anti-AFK thực tế (Giúp không bị văng game sau 20p)
_G.AntiAFK = false
SettingTab:AddToggle("Bật Anti-AFK", function(state)
    _G.AntiAFK = state
    if state then
        local VirtualUser = game:GetService("VirtualUser")
        game:GetService("Players").LocalPlayer.Idled:Connect(function()
            if _G.AntiAFK then
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end
        end)
        Plexus:Notification("Anti-AFK", "Đã bật chế độ chống treo máy!", 2)
    end
end)

-- Chức năng Màn hình Trắng (Giảm lag cực mạnh khi treo máy)
SettingTab:AddToggle("Màn hình Trắng (AFK Farm)", function(state)
    if state then
        game:GetService("RunService"):Set3dRenderingEnabled(false)
    else
        game:GetService("RunService"):Set3dRenderingEnabled(true)
    end
end)

-- Đổi màu nền Menu (Color Picker)
SettingTab:AddLabel("🎨 Đổi màu nền Menu")
SettingTab:AddColorPicker("Chọn màu", Color3.fromRGB(57, 141, 168), function(color)
    -- Thư viện sẽ tự nhận diện màu nếu hỗ trợ
end)

-- Nút Đóng Menu
SettingTab:AddLabel("Menu Script")
SettingTab:AddButton("❌ Đóng Menu & Tắt toàn bộ chức năng", function()
    for i,v in pairs(game.CoreGui:GetChildren()) do
        if v.Name == "Plexus" then v:Destroy() end
    end
end)

